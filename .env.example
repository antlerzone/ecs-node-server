# Copy to `.env` and fill values. Do not commit real secrets.

# --- Tenant rent auto-debit (daily cron) ---
#ENABLE_TENANT_XENDIT_AUTO_DEBIT=1
#ENABLE_TENANT_STRIPE_AUTO_DEBIT=1
#TENANT_XENDIT_AUTO_DEBIT_MAX_PER_RUN=30
#TENANT_STRIPE_AUTO_DEBIT_MAX_PER_RUN=30

# Cron auth (required in production if CRON_SECRET is set)
#CRON_SECRET=

# Portal JWT (password + OAuth login for /enquiry, /portal, …). Default in code is 12h; was 5m and caused UNAUTHORIZED mid-wizard.
#PORTAL_JWT_SECRET=
#PORTAL_JWT_EXPIRES_IN=12h

# --- Coliving SaaS: Stripe Checkout (operator plan, credit top-up, /enquiry plan pay) — MY platform account only ---
# Default: sandbox (STRIPE_SANDBOX_SECRET_KEY). For portal.colivingjb.com production: set live key + webhook, then enable SaaS live:
#   COLIVING_SAAS_STRIPE_LIVE=1   OR   COLIVING_SAAS_STRIPE_USE_SANDBOX=0
# Requires STRIPE_SECRET_KEY=sk_live_... and STRIPE_WEBHOOK_SECRET from Stripe Dashboard (Live). Do not set FORCE_PAYMENT_SANDBOX on production ECS.
#COLIVING_SAAS_STRIPE_LIVE=1
#COLIVING_SAAS_STRIPE_USE_SANDBOX=0
# SGD only: extra Stripe line-item % on plan/top-up (default 10). MYR has 0% platform transaction fee on that checkout.
#COLIVING_SAAS_STRIPE_TRANSACTION_FEE_PERCENT=10

# --- Payment fee estimates (actual Stripe/Xendit fees vary by card/rail; SaaS markup is fixed 1% in code) ---
# Stripe Checkout UI: estimated gateway % when showing tenant/operator amounts (actual fee from balance_transaction at capture)
#STRIPE_ESTIMATE_GATEWAY_PERCENT=4.5
# Xendit settlement journal fallback when net_amount missing
#XENDIT_ESTIMATE_GATEWAY_PERCENT=4.5
# Xendit split rule: floor(100 - 1% SaaS - this) when XENDIT_OPERATOR_SPLIT_PERCENT unset
#XENDIT_MAX_GATEWAY_PERCENT=5.5
# Optional integer override for Xendit split % to operator (e.g. 93)
#XENDIT_OPERATOR_SPLIT_PERCENT=

# --- Coliving SaaS: enquiry MYR 方案款（新单走平台 Xendit，与 Operator billing/credit 同套 XENDIT_PLATFORM_* + webhook token 变量）---
# Legacy Billplz（仅处理在途旧单）+ webhook /api/billplz/saas-coliving-callback：
# Set on ECS Node; Google OAuth redirect 只需已登記的 .../api/portal-auth/google/callback（enquiry 用 state，無需第二條 URI）
# 若只用 Xendit，Billplz 可不配；缺 key 时旧 Billplz webhook 会回 SAAS_BILLPLZ_NOT_CONFIGURED
#SAAS_COLIVING_PUBLIC_API_BASE=https://api.colivingjb.com
#SAAS_COLIVING_BILLPLZ_API_KEY=
#SAAS_COLIVING_BILLPLZ_COLLECTION_ID=
#SAAS_COLIVING_BILLPLZ_X_SIGNATURE_KEY=
#SAAS_COLIVING_BILLPLZ_USE_SANDBOX=0
# Optional: redirect after Billplz payment (default portal /enquiry?paid=1)
#SAAS_COLIVING_BILLPLZ_REDIRECT_URL=https://portal.colivingjb.com/enquiry?paid=1

# --- Coliving SaaS: Operator Portal pricing plan + credit top-up (platform Xendit Invoice → POST /api/payex/callback) ---
# Live production: XENDIT_PLATFORM_SECRET_KEY (live). Leave XENDIT_PLATFORM_USE_TEST unset; set XENDIT_SAAS_PLATFORM_LIVE_CALLBACK_TOKEN to match Xendit Dashboard verification token for /api/payex/callback.
# Sandbox/dev: XENDIT_PLATFORM_TEST_SECRET_KEY + XENDIT_PLATFORM_USE_TEST=1 + XENDIT_SAAS_PLATFORM_TEST_CALLBACK_TOKEN.
# Uses XENDIT_PLATFORM_SECRET_KEY (or XENDIT_PLATFORM_TEST_SECRET_KEY + XENDIT_PLATFORM_USE_TEST=1).
# Xendit master dashboard: invoice callback URL https://<api>/api/payex/callback — paste Verification Token per environment:
#XENDIT_SAAS_PLATFORM_TEST_CALLBACK_TOKEN=
#XENDIT_SAAS_PLATFORM_LIVE_CALLBACK_TOKEN=
# Optional legacy single token if TEST/LIVE unset:
#XENDIT_SAAS_PLATFORM_CALLBACK_TOKEN=
# Callback URL host (same idea as Billplz SaaS block above):
#SAAS_COLIVING_PUBLIC_API_BASE=https://api.colivingjb.com
# SGD SaaS checkout: default payment_session (POST /sessions PAYMENT_LINK). Portal /enquiry SGD uses same flow as MYR when unset. Set disabled/manual/saas_admin to turn off SGD online pay. v3: payment_request_v3 (+ optional XENDIT_SAAS_SG_V3_MID_LABEL).
#XENDIT_SAAS_SGD_CHECKOUT_MODE=payment_session
#XENDIT_SAAS_SGD_CHECKOUT_MODE=payment_request_v3
#XENDIT_SAAS_SGD_CHECKOUT_MODE=disabled
#XENDIT_SAAS_SG_V3_MID_LABEL=
# Optional: restrict Session hosted checkout to cards — JSON array, e.g. ["CARDS"]. Leave unset while debugging "no channels" errors.
#XENDIT_SAAS_SGD_SESSION_ALLOWED_CHANNELS=

# --- Antlerzone → Cleanlemons: POST /api/cleanlemon-sync/antlerzone-property (Bearer or X-Sync-Secret) ---
# Same secret value as Wix Secrets AntlerzoneImportSecret / AntlerzoneEcsSyncSecret (if used).
#ANTLERZONE_CLEANLEMONS_SYNC_SECRET=
# cln_operatordetail.id for Antlerzone on Cleanlemons MySQL
#ANTLERZONE_CLEANLEMONS_OPERATOR_ID=
# Optional legacy FKs on cln_property
#ANTLERZONE_CLN_CLIENT_ID=
#ANTLERZONE_CLN_CLIENTDETAIL_ID=
