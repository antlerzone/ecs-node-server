# ECS backend base URL. Node (server.js) listens on port 5000 (see repo root: npm start).
# Same machine (local or ECS): MUST use 127.0.0.1:5000 so Next proxy talks to local Node (avoids nginx 502).
# If you see 502 on /api/portal/proxy/billing/indoor-admin/*: set ECS_BASE_URL below and restart Portal.
# Different machines: set to public API URL (e.g. https://api.colivingjb.com).
# See docs/nextjs-migration/NEXT-NODE-BINDING.md for full binding guide.
NEXT_PUBLIC_ECS_BASE_URL=https://api.colivingjb.com
# Operator tutorial PDFs: default uses ECS GET /api/public/operator-tutorial-pdf?file=… (redirects to OSS signed URL).
# Optional: direct OSS URL prefix if bucket allows public read on portal/tutorial/operator/* — no trailing slash
# NEXT_PUBLIC_OPERATOR_TUTORIAL_OSS_BASE=https://your-bucket.oss-ap-southeast-3.aliyuncs.com/portal/tutorial/operator
# Server-side proxy target: on ECS set to local Node so /api/portal/proxy/* does not go through nginx (prevents 502).
ECS_BASE_URL=http://127.0.0.1:5000
# Or force local backend regardless of ECS_BASE_URL:
# FORCE_LOCAL_BACKEND=1

# Login 頁是否顯示 Demo Credentials（demo@coliving.my）。portal 部署請設為 false；demo 站可不設或 true
# NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# ECS API auth (server-only; do not use NEXT_PUBLIC_ for these)
# Required for /api/access/* (member-roles, context, context/with-client) and other protected routes
ECS_API_TOKEN=
ECS_API_USERNAME=
